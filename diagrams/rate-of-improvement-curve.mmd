graph LR
    W0["📍 Week 0\nBaseline\nI₀ = 0%"]
    W1["Week 1-4\n🚀 Rapid\nAcceleration\nRoI = HIGH"]
    W2["Week 5-10\n📈 Tapering\nRoI = DECLINING\n(normal)"]
    W3["Week 11+\n✅ Stabilization\nRoI ≈ 0\nValue sustained"]

    W0 --> W1 --> W2 --> W3

    subgraph SHAPES["Curve Shape Diagnostics"]
        S1["✅ S-Curve\nrise → taper → flat\nSUCCESS"]
        S2["⚠️ Rise-Decline\nimprovement then\nregression → WARN"]
        S3["❌ Flat Line\nno improvement\nFAILURE - redesign"]
        S4["🔍 Unbounded\ncontinuous rise\nINVESTIGATE"]
    end

    W3 -.->|"healthy"| S1
    W2 -.->|"if declining"| S2
    W1 -.->|"if stuck"| S3
    W3 -.->|"if still rising"| S4

    FORMULA["📐 RoI Formula\nRoI(t) = ΔI / Δt\nwhere I = improvement %\nvs baseline\nSuccess: R² > 0.85\non logistic fit"]

    style W0 fill:#2a2a2a,color:#fff,stroke:#6b7280
    style W1 fill:#1a4a2e,color:#fff,stroke:#4ade80
    style W2 fill:#3a3a1a,color:#fff,stroke:#facc15
    style W3 fill:#1a3a5c,color:#fff,stroke:#4a9ede
    style S1 fill:#1a4a2e,color:#fff,stroke:#4ade80
    style S2 fill:#3a3a1a,color:#fff,stroke:#facc15
    style S3 fill:#4a1a1a,color:#fff,stroke:#f87171
    style S4 fill:#1a3a5c,color:#fff,stroke:#4a9ede
    style FORMULA fill:#1a1a3a,color:#fff,stroke:#a78bfa
