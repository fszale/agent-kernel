graph TB
    subgraph PPT["People, Process, Technology Evaluation Matrix"]
        subgraph P["People"]
            P_REV["Revenue\nWho benefits?\nHow much?"]
            P_RISK["Risk\nWho is at risk?\nDownside?"]
            P_COST["Cost\nTraining, change management"]
        end

        subgraph PR["Process"]
            PR_REV["Revenue\nRevenue-process improvements?"]
            PR_RISK["Risk\nOperational risk reduction?"]
            PR_COST["Cost\nEfficiency gains, automation?"]
        end

        subgraph T["Technology"]
            T_REV["Revenue\nTech-enabled expansion?"]
            T_RISK["Risk\nSecurity and reliability risks?"]
            T_COST["Cost\nBuild vs buy, maintenance?"]
        end
    end

    subgraph VS["Value Stream Output"]
        REV["Revenue Generation"]
        RISK["Risk Mitigation"]
        COST["Cost Savings"]
    end

    P_REV --> REV
    PR_REV --> REV
    T_REV --> REV
    P_RISK --> RISK
    PR_RISK --> RISK
    T_RISK --> RISK
    P_COST --> COST
    PR_COST --> COST
    T_COST --> COST

    SCORE["Score 1-10 per cell\n9 scores total\nMax = 90\n75+ Strong\n55-74 Promising\n35-54 Marginal\n0-34 Weak"]

    REV --> SCORE
    RISK --> SCORE
    COST --> SCORE

    style P fill:#1a3a5c,color:#fff,stroke:#4a9ede
    style PR fill:#1a4a2e,color:#fff,stroke:#4ade80
    style T fill:#3a2a5c,color:#fff,stroke:#a78bfa
    style VS fill:#2a2a2a,color:#fff,stroke:#6b7280
    style SCORE fill:#1a1a3a,color:#fff,stroke:#a78bfa
